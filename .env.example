# Optional local environment variables for Vibe Hub
#
# Copy this file to `.env` only for local use.
# Do not commit your real `.env` file.

# Bridge host/port
VIBE_HUB_HOST=127.0.0.1
VIBE_HUB_PORT=4765
VIBE_HUB_BRIDGE_URL=http://127.0.0.1:4765

# Optional local LLM key
# Keep real secrets only on your own machine.
VIBE_HUB_LLM_API_KEY=your_api_key_here

